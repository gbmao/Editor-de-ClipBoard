{
  "name": "editor-de-clipboard",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "author": "Fadami",
  "description": "Frontend mínimo de bandeja para o Editor de Clipboard.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check src/main.js",
    "dist": "electron-builder --win nsis",
    "portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.editor-de-clipboard.app",
    "productName": "Editor de Clipboard",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^26.15.3"
  }
}
